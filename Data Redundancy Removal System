const express = require('express');
const mongoose = require('mongoose');

const app = express();
app.use(express.json());

// Connect MongoDB
mongoose.connect('mongodb://127.0.0.1:27017/redundancyDB')
.then(() => console.log("DB Connected"))
.catch(err => console.log(err));

// Schema
const dataSchema = new mongoose.Schema({
    name: String,
    email: { type: String, unique: true }, // prevents duplicates
    age: Number
});

const Data = mongoose.model('Data', dataSchema);



app.post('/add', async (req, res) => {
    try {
        const { name, email, age } = req.body;

        // Basic Validation
        if (!name || !email) {
            return res.status(400).send("Invalid Data");
        }

        // Check Duplicate
        const existing = await Data.findOne({ email });

        if (existing) {
            return res.status(400).send("Duplicate Data Found");
        }

        // Save Unique Data
        const newData = new Data({ name, email, age });
        await newData.save();

        res.send("Data Added Successfully");

    } catch (error) {
        res.status(500).send(error.message);
    }
});



app.get('/data', async (req, res) => {
    const data = await Data.find();
    res.json(data);
});





app.delete('/remove-duplicates', async (req, res) => {
    const duplicates = await Data.aggregate([
        {
            $group: {
                _id: "$email",
                count: { $sum: 1 },
                ids: { $push: "$_id" }
            }
        },
        {
            $match: { count: { $gt: 1 } }
        }
    ]);

    for (let dup of duplicates) {
        dup.ids.shift(); // keep one
        await Data.deleteMany({ _id: { $in: dup.ids } });
    }

    res.send("Duplicates Removed");
});




app.listen(3000, () => {
    console.log("Server running on port 3000");
});
